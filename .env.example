# Optional: publish your products Google Sheet to the web as CSV
# (File → Share → Publish to web → select sheet → CSV → Publish) and paste
# the link here to go live. Leave unset to use the bundled sample catalog.
# Columns must match Computec Products Template.csv.
SHEET_CSV_URL=

# Owner dashboard login. CHANGE BOTH before deploying anywhere public.
# ADMIN_PASSWORD: the password you type at /manager-pos/login
# ADMIN_SESSION_SECRET: a long random string used to sign session cookies
ADMIN_PASSWORD=computec-admin
ADMIN_SESSION_SECRET=change-this-to-a-long-random-string

# Production data store (Upstash Redis). REQUIRED on Vercel / any serverless host
# — without these the app falls back to local files, which don't persist there.
# Create a free database at upstash.com (or via the Vercel Upstash integration,
# which sets these automatically). Leave blank for local dev to use /data files.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
